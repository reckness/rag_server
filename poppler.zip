             <script>
    $(function() {
        bizx.cmp.ifConsent({ purposes: 'all' , vendors: 'narrative'}, function() {
            var current_time = (new Date()).getTime();
            let imageUrl = "https://io.narrative.io/?companyId=2440&id=first_party%3Acd63b952-4441-4580-82e2-ba376944fe31&id=site_name%3Asourceforge.net&id=url%3A%2Fprojects%2Fpoppler-win32%2Ffiles%2Flatest%2Fdownload&id=pagetitle%3ADownload+Poppler+Win32&id=vertical%3AOpen+Source+Software&id=product%3APoppler+Win32&id=topics%3ALibraries&id=programming_language%3AC%2B%2B&id=action%3ADownloaded+Poppler+Win32&id=action%3ADownloaded+Libraries+Software";
            imageUrl = imageUrl.replace(encodeURIComponent("$PAGE_TITLE"), document.title);  

            imageUrl = URL.parse(imageUrl);
            let hem = bizx.uids.getHem();
            if (hem) {
                imageUrl.searchParams.append('id', 'hem:' + hem);
            }
            imageUrl.searchParams.append('rand', current_time);

            var image = new Image();
            image.src = imageUrl.toString();
            image.style.display = "none";
            image.style.height = 0;
            image.style.width = 0;
            document.body.appendChild(image);
        });
    });
</script>
        

        
            
